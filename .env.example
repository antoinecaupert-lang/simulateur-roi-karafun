# Copier ce fichier en .env.local pour le dev local
# Sur Vercel : configurer ces variables dans Settings > Environment Variables

# Anthropic Claude — pour l'analyse IA personnalisée
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# HubSpot — pour la capture de leads CRM
